function hexToRgb(hex) { const h=hex.replace("#",""); return [parseInt(h.slice(0,2),16),parse
function rgbToHsl(r,g,b) { r/=255;g/=255;b/=255; const max=Math.max(r,g,b),min=Math.min(r,g,b
function isValidHex(s){return /^#[0-9a-fA-F]{6}$/.test(s.trim());}
function isSpectral(hue){return hue<=270;}
function proceduralFromColour(hex){
const [r,g,b]=hexToRgb(hex); const [h,s,l]=rgbToHsl(r,g,b);
const rows=3+Math.floor(s/14); const cols=24+Math.floor(h/15);
const fr=(r/255)*Math.PI*2.1; const fg=(g/255)*Math.PI*1.7; const fb=(b/255)*Math.PI*2.4;
const visual=[];
for(let y=0;y<rows;y++){let line=" ";for(let x=0;x<cols;x++){const amp=Math.sin(x*fr+y*0.
visual.push(""); visual.push(" colour : "+hex); visual.push(" hsl : "+h+"\u00b0 "
if(!isSpectral(h))visual.push(" note : non-spectral"); visual.push(""); return visual;
}
const COLOUR_KEY="perrin-favourite-colour";
// Mobile detection — used to adjust rendering performance and layout
const IS_MOBILE = /iPhone|iPad|iPod|Android|Mobile/i.test(
typeof navigator !== "undefined" ? navigator.userAgent : ""
) || (typeof window !== "undefined" && window.innerWidth < 600);
async function loadFavouriteColour(){
try{
if(window.storage?.get){const result=await window.storage.get(COLOUR_KEY);return result?.
return localStorage.getItem(COLOUR_KEY)||null;
}catch{try{return localStorage.getItem(COLOUR_KEY)||null;}catch{return null;}}
}
async function saveFavouriteColour(hex){
try{if(window.storage?.set){await window.storage.set(COLOUR_KEY,hex);return;}}catch{}
try{localStorage.setItem(COLOUR_KEY,hex);}catch{}
}
