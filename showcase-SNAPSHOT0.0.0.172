function detectMood(text) {
const s = text.toLowerCase();
if (/dream|sleep|dreaming|asleep/.test(s)) if (/inbetween|in.between|liminal|between/.test(s)) if (/burn|fire|flame|ash/.test(s)) if (/love|beautiful|beauty/.test(s)) if (/void|null|empty|nothing/.test(s)) if (/potsu|music|guitar|song|sing|lofi|lo.fi|sound/.test(s)) if (/megetremia/.test(s)) if (/shea/.test(s)) if (/shadow|dark|absence|penumbra|dim/.test(s)) return MOODS.shadow;
return MOODS.dream;
if (/yggdrasil|norse|odin|raven|norn|ragnar|root|tree/.test(s))return MOODS.norse;
return MOODS.inbetween;
return MOODS.fire;
return MOODS.love;
return MOODS.void;
return MOODS.music;
return MOODS.megetremia;
return MOODS.shea;
if (/pink|rose|blush|tender|soft|pale|delicate/.test(s)) return MOODS.pink;
return null;
}
